{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/verifier-identity-evidence.schema.json",
  "title": "Verifier Identity Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "verifier_id",
    "trust_policy_id",
    "repository_binding",
    "purposes",
    "workload_identity",
    "binding_statement",
    "signatures",
    "transparency",
    "evidence_sha256",
    "issued_at",
    "expires_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "VerifierIdentityEvidence" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "verifier_id": { "$ref": "common.schema.json#/$defs/id" },
    "trust_policy_id": { "$ref": "common.schema.json#/$defs/id" },
    "repository_binding": { "$ref": "#/$defs/repository_binding" },
    "purposes": { "$ref": "#/$defs/purposes" },
    "workload_identity": {
      "type": "object",
      "required": ["type", "spiffe_id", "trust_root_id", "leaf_certificate_pem", "certificate_chain_pem"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "spiffe_x509" },
        "spiffe_id": { "type": "string", "pattern": "^spiffe://[a-z0-9.-]+/[^?#]+$" },
        "trust_root_id": { "$ref": "common.schema.json#/$defs/id" },
        "leaf_certificate_pem": { "type": "string", "pattern": "^-----BEGIN CERTIFICATE-----" },
        "certificate_chain_pem": {
          "type": "array",
          "maxItems": 10,
          "items": { "type": "string", "pattern": "^-----BEGIN CERTIFICATE-----" }
        }
      }
    },
    "binding_statement": {
      "type": "object",
      "required": [
        "schema_version",
        "type",
        "evidence_id",
        "verifier_id",
        "verifier_key_id",
        "spiffe_id",
        "trust_root_id",
        "transparency_log_id",
        "repository_binding",
        "purposes",
        "nonce",
        "issued_at",
        "expires_at"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "0.1" },
        "type": { "type": "string", "const": "VerifierIdentityBinding" },
        "evidence_id": { "$ref": "common.schema.json#/$defs/id" },
        "verifier_id": { "$ref": "common.schema.json#/$defs/id" },
        "verifier_key_id": { "$ref": "#/$defs/sha256" },
        "spiffe_id": { "type": "string", "pattern": "^spiffe://[a-z0-9.-]+/[^?#]+$" },
        "trust_root_id": { "$ref": "common.schema.json#/$defs/id" },
        "transparency_log_id": { "$ref": "common.schema.json#/$defs/id" },
        "repository_binding": { "$ref": "#/$defs/repository_binding" },
        "purposes": { "$ref": "#/$defs/purposes" },
        "nonce": { "type": "string", "minLength": 16, "maxLength": 256 },
        "issued_at": { "$ref": "common.schema.json#/$defs/timestamp" },
        "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" }
      }
    },
    "signatures": {
      "type": "object",
      "required": [
        "workload_key_id",
        "workload_algorithm",
        "workload_signature_base64",
        "verifier_key_id",
        "verifier_algorithm",
        "verifier_signature_base64"
      ],
      "additionalProperties": false,
      "properties": {
        "workload_key_id": { "$ref": "#/$defs/sha256" },
        "workload_algorithm": { "type": "string", "const": "ed25519" },
        "workload_signature_base64": { "$ref": "#/$defs/base64" },
        "verifier_key_id": { "$ref": "#/$defs/sha256" },
        "verifier_algorithm": { "type": "string", "const": "ed25519" },
        "verifier_signature_base64": { "$ref": "#/$defs/base64" }
      }
    },
    "transparency": {
      "type": "object",
      "required": [
        "log_id",
        "canonicalized_entry_base64",
        "leaf_hash",
        "log_index",
        "tree_size",
        "inclusion_path_sha256",
        "checkpoint"
      ],
      "additionalProperties": false,
      "properties": {
        "log_id": { "$ref": "common.schema.json#/$defs/id" },
        "canonicalized_entry_base64": { "$ref": "#/$defs/base64" },
        "leaf_hash": { "$ref": "#/$defs/sha256" },
        "log_index": { "type": "integer", "minimum": 0 },
        "tree_size": { "type": "integer", "minimum": 1 },
        "inclusion_path_sha256": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/sha256" }
        },
        "checkpoint": {
          "type": "object",
          "required": ["origin", "log_id", "tree_size", "root_hash", "issued_at", "key_id", "signature_algorithm", "signature_base64"],
          "additionalProperties": false,
          "properties": {
            "origin": { "type": "string", "minLength": 1, "maxLength": 256 },
            "log_id": { "$ref": "common.schema.json#/$defs/id" },
            "tree_size": { "type": "integer", "minimum": 1 },
            "root_hash": { "$ref": "#/$defs/sha256" },
            "issued_at": { "$ref": "common.schema.json#/$defs/timestamp" },
            "key_id": { "$ref": "#/$defs/sha256" },
            "signature_algorithm": { "type": "string", "const": "ed25519" },
            "signature_base64": { "$ref": "#/$defs/base64" }
          }
        }
      }
    },
    "evidence_sha256": { "$ref": "#/$defs/sha256" },
    "issued_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  },
  "$defs": {
    "base64": {
      "type": "string",
      "minLength": 4,
      "pattern": "^[A-Za-z0-9+/]+={0,2}$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "repository_binding": {
      "type": "object",
      "required": ["repository_key", "identity_fingerprint"],
      "additionalProperties": false,
      "properties": {
        "repository_key": { "type": "string", "minLength": 1 },
        "identity_fingerprint": { "$ref": "#/$defs/sha256" }
      }
    },
    "purposes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["verification_receipt", "comparative_evaluation_report"]
      }
    }
  }
}
