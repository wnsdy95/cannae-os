{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/trust-root-rotation.schema.json",
  "title": "Trust Root Rotation",
  "type": "object",
  "required": [
    "schema_version", "type", "id", "policy_id", "previous_trusted_root_ref",
    "next_trusted_root_ref", "previous_trusted_root_sha256", "next_trusted_root_sha256",
    "previous_tuf_root", "next_tuf_root", "previous_tuf_root_sha256", "next_tuf_root_sha256",
    "reason", "revoked_tuf_root_key_ids", "approved_by", "approved_at", "effective_at",
    "rotation_sha256"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "TrustRootRotation" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "policy_id": { "$ref": "common.schema.json#/$defs/id" },
    "previous_trusted_root_ref": { "$ref": "#/$defs/artifact_ref" },
    "next_trusted_root_ref": { "$ref": "#/$defs/artifact_ref" },
    "previous_trusted_root_sha256": { "$ref": "#/$defs/sha256" },
    "next_trusted_root_sha256": { "$ref": "#/$defs/sha256" },
    "previous_tuf_root": { "$ref": "#/$defs/tuf_root" },
    "next_tuf_root": { "$ref": "#/$defs/tuf_root" },
    "previous_tuf_root_sha256": { "$ref": "#/$defs/sha256" },
    "next_tuf_root_sha256": { "$ref": "#/$defs/sha256" },
    "reason": { "type": "string", "enum": ["scheduled", "compromise", "log_shard", "operator_transition", "algorithm_migration"] },
    "revoked_tuf_root_key_ids": {
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "approved_by": { "type": "string", "const": "USER" },
    "approved_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "effective_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "rotation_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifact_ref": {
      "type": "object",
      "required": ["artifact_id", "relative_path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "$ref": "common.schema.json#/$defs/id" },
        "relative_path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "tuf_root": {
      "type": "object",
      "required": ["signatures", "signed"],
      "additionalProperties": false,
      "properties": {
        "signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["keyid", "sig"],
            "additionalProperties": false,
            "properties": {
              "keyid": { "type": "string", "minLength": 1 },
              "sig": { "type": "string", "minLength": 1 }
            }
          }
        },
        "signed": {
          "type": "object",
          "required": ["_type", "spec_version", "version", "expires", "keys", "roles"],
          "properties": {
            "_type": { "type": "string", "const": "root" },
            "spec_version": { "type": "string", "minLength": 1 },
            "version": { "type": "integer", "minimum": 1 },
            "expires": { "$ref": "common.schema.json#/$defs/timestamp" },
            "keys": { "type": "object", "minProperties": 1 },
            "roles": { "type": "object", "required": ["root", "snapshot", "targets", "timestamp"] }
          }
        }
      }
    }
  }
}
