{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/model-usage-event.schema.json",
  "title": "Model Usage Event",
  "type": "object",
  "required": ["schema_version", "type", "id", "mission_id", "wave_id", "registry_id", "registry_version", "assignment_request_id", "compiled_plan_id", "agent_id", "billet_id", "task", "model_profile_id", "model_family", "model_version", "harness_version", "system_prompt_version", "tool_schema_version", "event_type", "authority_scope_snapshot", "release_target", "metrics", "evidence", "classification", "observed_at"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.2" },
    "type": { "type": "string", "const": "ModelUsageEvent" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "wave_id": { "type": "string", "minLength": 1 },
    "registry_id": { "$ref": "common.schema.json#/$defs/id" },
    "registry_version": { "type": "string", "minLength": 1 },
    "assignment_request_id": { "$ref": "common.schema.json#/$defs/id" },
    "compiled_plan_id": { "$ref": "common.schema.json#/$defs/id" },
    "agent_id": { "type": "string", "minLength": 1 },
    "billet_id": { "$ref": "common.schema.json#/$defs/id" },
    "task": { "type": "string", "minLength": 1 },
    "model_profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "model_family": { "type": "string", "minLength": 1 },
    "model_version": { "type": "string", "minLength": 1 },
    "harness_version": { "type": "string", "minLength": 1 },
    "system_prompt_version": { "type": "string", "minLength": 1 },
    "tool_schema_version": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "enum": ["dispatched", "completed", "failed", "escalated", "fallback_activated", "blocked"] },
    "previous_profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "next_profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "authority_scope_snapshot": { "$ref": "common.schema.json#/$defs/string_list" },
    "release_target": { "type": "string", "enum": ["no_release", "internal_handoff", "final_output", "external_release"] },
    "metrics": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "latency_ms", "estimated_cost_units", "attempt"],
      "additionalProperties": false,
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "latency_ms": { "type": "integer", "minimum": 0 },
        "estimated_cost_units": { "type": "number", "minimum": 0 },
        "attempt": { "type": "integer", "minimum": 1 }
      }
    },
    "evidence": { "$ref": "common.schema.json#/$defs/string_list" },
    "failure_codes": { "$ref": "common.schema.json#/$defs/string_list" },
    "classification": { "$ref": "common.schema.json#/$defs/classification" },
    "observed_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
