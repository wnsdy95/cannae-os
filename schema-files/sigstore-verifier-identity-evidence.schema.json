{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/sigstore-verifier-identity-evidence.schema.json",
  "title": "Sigstore Verifier Identity Evidence",
  "type": "object",
  "required": [
    "schema_version", "type", "id", "verifier_id", "trust_policy_id", "repository_binding",
    "purposes", "workload_identity", "binding_statement", "signatures", "sigstore",
    "evidence_sha256", "issued_at", "expires_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "SigstoreVerifierIdentityEvidence" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "verifier_id": { "$ref": "common.schema.json#/$defs/id" },
    "trust_policy_id": { "$ref": "common.schema.json#/$defs/id" },
    "repository_binding": { "$ref": "#/$defs/repository_binding" },
    "purposes": { "$ref": "#/$defs/purposes" },
    "workload_identity": { "$ref": "#/$defs/workload_identity" },
    "binding_statement": {
      "type": "object",
      "required": [
        "schema_version", "type", "evidence_id", "verifier_id", "verifier_key_id",
        "certificate_identity_type", "certificate_identity", "certificate_issuer", "trust_root_id",
        "trusted_root_sha256", "repository_binding", "purposes", "nonce", "issued_at", "expires_at"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "0.1" },
        "type": { "type": "string", "const": "SigstoreVerifierIdentityBinding" },
        "evidence_id": { "$ref": "common.schema.json#/$defs/id" },
        "verifier_id": { "$ref": "common.schema.json#/$defs/id" },
        "verifier_key_id": { "$ref": "#/$defs/sha256" },
        "certificate_identity_type": { "type": "string", "enum": ["email", "uri"] },
        "certificate_identity": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "certificate_issuer": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "trust_root_id": { "$ref": "common.schema.json#/$defs/id" },
        "trusted_root_sha256": { "$ref": "#/$defs/sha256" },
        "repository_binding": { "$ref": "#/$defs/repository_binding" },
        "purposes": { "$ref": "#/$defs/purposes" },
        "nonce": { "type": "string", "minLength": 16, "maxLength": 256 },
        "issued_at": { "$ref": "common.schema.json#/$defs/timestamp" },
        "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" }
      }
    },
    "signatures": {
      "type": "object",
      "required": ["verifier_key_id", "verifier_algorithm", "verifier_signature_base64"],
      "additionalProperties": false,
      "properties": {
        "verifier_key_id": { "$ref": "#/$defs/sha256" },
        "verifier_algorithm": { "type": "string", "const": "ed25519" },
        "verifier_signature_base64": { "$ref": "#/$defs/base64" }
      }
    },
    "sigstore": {
      "type": "object",
      "required": ["bundle_media_type", "bundle_sha256", "bundle"],
      "additionalProperties": false,
      "properties": {
        "bundle_media_type": {
          "type": "string",
          "enum": [
            "application/vnd.dev.sigstore.bundle+json;version=0.2",
            "application/vnd.dev.sigstore.bundle.v0.3+json",
            "application/vnd.dev.sigstore.bundle+json;version=0.3"
          ]
        },
        "bundle_sha256": { "$ref": "#/$defs/sha256" },
        "bundle": {
          "type": "object",
          "required": ["mediaType", "verificationMaterial", "messageSignature"],
          "additionalProperties": false,
          "properties": {
            "mediaType": { "type": "string" },
            "verificationMaterial": { "type": "object" },
            "messageSignature": { "type": "object" }
          }
        }
      }
    },
    "evidence_sha256": { "$ref": "#/$defs/sha256" },
    "issued_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  },
  "$defs": {
    "base64": { "type": "string", "minLength": 4, "pattern": "^[A-Za-z0-9+/]+={0,2}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "repository_binding": {
      "type": "object",
      "required": ["repository_key", "identity_fingerprint"],
      "additionalProperties": false,
      "properties": {
        "repository_key": { "type": "string", "minLength": 1 },
        "identity_fingerprint": { "$ref": "#/$defs/sha256" }
      }
    },
    "purposes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["verification_receipt", "comparative_evaluation_report"] }
    },
    "workload_identity": {
      "type": "object",
      "required": [
        "type", "certificate_identity_type", "certificate_identity", "certificate_issuer",
        "trust_root_id", "trusted_root_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "sigstore_bundle" },
        "certificate_identity_type": { "type": "string", "enum": ["email", "uri"] },
        "certificate_identity": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "certificate_issuer": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "trust_root_id": { "$ref": "common.schema.json#/$defs/id" },
        "trusted_root_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
