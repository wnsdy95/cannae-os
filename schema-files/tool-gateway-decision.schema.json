{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/tool-gateway-decision.schema.json",
  "title": "Tool Gateway Decision",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "transaction_id",
    "mission_id",
    "wave_id",
    "agent_id",
    "provider",
    "request_ref",
    "lease_ref",
    "tool_policy_ref",
    "checkpoint_ref",
    "admission_ref",
    "gateway_binding_sha256",
    "principal_binding_sha256",
    "tool_call",
    "repository_state_before",
    "coordination",
    "decision",
    "execution_permitted",
    "production_execution_authorized",
    "matched_rule_id",
    "reason_codes",
    "idempotency_key",
    "decided_at",
    "valid_until",
    "authority"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "ToolGatewayDecision" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "transaction_id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "wave_id": { "$ref": "#/$defs/safe_identifier" },
    "agent_id": { "$ref": "#/$defs/safe_identifier" },
    "provider": { "$ref": "#/$defs/provider" },
    "request_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "lease_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "tool_policy_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "checkpoint_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "admission_ref": { "$ref": "#/$defs/artifact_ref_or_none" },
    "gateway_binding_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "principal_binding_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "tool_call": { "$ref": "#/$defs/tool_call" },
    "repository_state_before": { "$ref": "#/$defs/repository_state" },
    "coordination": { "$ref": "#/$defs/coordination" },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "execution_permitted": { "type": "boolean" },
    "production_execution_authorized": { "type": "boolean", "const": false },
    "matched_rule_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "reason_codes": { "$ref": "#/$defs/reason_codes" },
    "idempotency_key": { "$ref": "common.schema.json#/$defs/sha256" },
    "decided_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "valid_until": { "$ref": "common.schema.json#/$defs/timestamp" },
    "authority": { "$ref": "#/$defs/authority" }
  },
  "$defs": {
    "safe_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "provider": {
      "type": "string",
      "enum": ["codex", "claude_code"]
    },
    "artifact_ref_or_none": {
      "type": "object",
      "required": ["artifact_id", "relative_path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^(none|[A-Z]+-[A-Za-z0-9_-]+)$"
        },
        "relative_path": { "type": "string", "minLength": 1 },
        "sha256": {
          "type": "string",
          "pattern": "^(none|[a-f0-9]{64})$"
        }
      }
    },
    "tool_call": {
      "type": "object",
      "required": [
        "tool_use_id",
        "tool_name",
        "operation_class",
        "tool_input_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "tool_use_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "tool_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+/-]*$"
        },
        "operation_class": {
          "type": "string",
          "enum": [
            "observe",
            "repository_read",
            "repository_write",
            "process_execute",
            "network_access",
            "delegation"
          ]
        },
        "tool_input_sha256": { "$ref": "common.schema.json#/$defs/sha256" }
      }
    },
    "repository_state": {
      "type": "object",
      "required": ["head_commit", "worktree_fingerprint", "dirty"],
      "additionalProperties": false,
      "properties": {
        "head_commit": {
          "type": "string",
          "pattern": "^(unborn|[a-f0-9]{40,64})$"
        },
        "worktree_fingerprint": { "$ref": "common.schema.json#/$defs/sha256" },
        "dirty": { "type": "boolean" }
      }
    },
    "coordination": {
      "type": "object",
      "required": [
        "backend",
        "manifest_revision",
        "fencing_token"
      ],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["shared_filesystem_reference", "external_linearizable"]
        },
        "manifest_revision": {
          "type": "integer",
          "minimum": 1
        },
        "fencing_token": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "human_final_decision_authority",
        "self_approval_prohibited",
        "release_authorized"
      ],
      "additionalProperties": false,
      "properties": {
        "human_final_decision_authority": { "type": "string", "const": "USER" },
        "self_approval_prohibited": { "type": "boolean", "const": true },
        "release_authorized": { "type": "boolean", "const": false }
      }
    }
  }
}
