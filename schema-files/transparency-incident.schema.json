{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/transparency-incident.schema.json",
  "title": "Transparency Incident",
  "type": "object",
  "required": [
    "schema_version", "type", "id", "policy_id", "kind", "status", "severity",
    "detected_at", "affected_log_ids", "evidence_refs", "revocations",
    "containment_actions", "authority", "incident_sha256"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "resolved" } } },
      "then": { "required": ["supersedes_incident_ref", "resolution"] }
    }
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "TransparencyIncident" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "policy_id": { "$ref": "common.schema.json#/$defs/id" },
    "kind": {
      "type": "string",
      "enum": [
        "equivocation", "consistency_failure", "checkpoint_rollback", "checkpoint_stale",
        "witness_compromise", "monitor_compromise", "log_key_compromise", "tuf_root_rollback",
        "tuf_root_freeze", "unauthorized_root_rotation"
      ]
    },
    "status": { "type": "string", "enum": ["open", "contained", "resolved"] },
    "severity": { "type": "string", "const": "critical" },
    "detected_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "affected_log_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/id" }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": { "$ref": "#/$defs/artifact_ref" }
    },
    "revocations": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["subject_type", "subject_id", "effective_at", "reason"],
        "additionalProperties": false,
        "properties": {
          "subject_type": { "type": "string", "enum": ["log", "witness", "monitor", "key", "trusted_root"] },
          "subject_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "effective_at": { "$ref": "common.schema.json#/$defs/timestamp" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "containment_actions": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["block_dispatch", "freeze_trust_updates", "revoke_key", "rotate_root", "preserve_evidence", "notify_operator"]
      },
      "allOf": [
        { "contains": { "const": "block_dispatch" } },
        { "contains": { "const": "preserve_evidence" } }
      ]
    },
    "authority": { "type": "string", "const": "USER" },
    "supersedes_incident_ref": { "$ref": "#/$defs/artifact_ref" },
    "resolution": {
      "type": "object",
      "required": ["authority", "resolved_at", "evidence_refs", "rationale"],
      "additionalProperties": false,
      "properties": {
        "authority": { "type": "string", "const": "USER" },
        "resolved_at": { "$ref": "common.schema.json#/$defs/timestamp" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": { "$ref": "#/$defs/artifact_ref" }
        },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "incident_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifact_ref": {
      "type": "object",
      "required": ["artifact_id", "relative_path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "$ref": "common.schema.json#/$defs/id" },
        "relative_path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
