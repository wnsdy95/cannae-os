{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/self-improvement-cycle-order.schema.json",
  "title": "Self-Improvement Cycle Order",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "campaign_id",
    "mission_id",
    "repository_binding",
    "campaign_ref",
    "observed_manifest",
    "status",
    "transition",
    "cycle_number",
    "attempt_number",
    "baseline_revision",
    "parent_decision_ref",
    "source_checkpoint_ref",
    "source_decision_ref",
    "checkpoint_trigger",
    "task_order",
    "proof_requirements",
    "budget_snapshot",
    "execution_authorized",
    "release_authorized",
    "human_decision_required",
    "required_human_decision",
    "blocking_codes",
    "generated_at"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "enum": ["0.2", "0.3"] } } },
      "then": { "required": ["trust_policy_admission"] }
    },
    {
      "if": { "properties": { "schema_version": { "const": "0.3" } } },
      "then": {
        "properties": {
          "trust_policy_admission": { "required": ["identity_assurance"] }
        }
      }
    }
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1", "0.2", "0.3"] },
    "type": { "type": "string", "const": "SelfImprovementCycleOrder" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "campaign_id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "repository_binding": {
      "type": "object",
      "required": ["repository_key", "identity_fingerprint"],
      "additionalProperties": false,
      "properties": {
        "repository_key": { "type": "string", "minLength": 1 },
        "identity_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "campaign_ref": { "$ref": "#/$defs/artifact_ref" },
    "observed_manifest": {
      "type": "object",
      "required": ["revision", "sha256"],
      "additionalProperties": false,
      "properties": {
        "revision": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "status": { "type": "string", "enum": ["ready", "awaiting_human", "completed", "terminated", "blocked"] },
    "transition": { "type": "string", "enum": ["start", "retry", "advance", "before_completion", "hold"] },
    "cycle_number": { "type": "integer", "minimum": 1 },
    "attempt_number": { "type": "integer", "minimum": 1 },
    "baseline_revision": { "type": "string", "minLength": 1 },
    "parent_decision_ref": { "$ref": "#/$defs/decision_ref_or_none" },
    "source_checkpoint_ref": { "$ref": "#/$defs/artifact_ref_or_none" },
    "source_decision_ref": { "$ref": "#/$defs/artifact_ref_or_none" },
    "checkpoint_trigger": {
      "type": "string",
      "enum": ["wave_start", "wave_end", "validation_failure", "quality_regression", "scope_change", "before_completion", "manual"]
    },
    "task_order": {
      "type": "object",
      "required": ["owner", "task", "purpose", "constraints", "required_evidence", "next_checkpoint_trigger"],
      "additionalProperties": false,
      "properties": {
        "owner": { "$ref": "common.schema.json#/$defs/role_id" },
        "task": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "constraints": { "$ref": "common.schema.json#/$defs/string_list" },
        "required_evidence": { "$ref": "common.schema.json#/$defs/string_list" },
        "next_checkpoint_trigger": {
          "type": "string",
          "enum": ["wave_start", "wave_end", "validation_failure", "quality_regression", "scope_change", "before_completion", "manual"]
        }
      }
    },
    "proof_requirements": {
      "type": "object",
      "required": ["verification_receipt_required", "signed_attestation_required", "signed_comparative_attestation_required", "minimum_valid_attestations", "minimum_independence_groups", "require_distinct_key_ids", "trust_policy_ref"],
      "additionalProperties": false,
      "properties": {
        "verification_receipt_required": { "type": "boolean", "const": true },
        "comparative_evaluation_required_for": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["runtime_control", "skill"] }
        },
        "signed_attestation_required": { "type": "boolean" },
        "signed_comparative_attestation_required": { "type": "boolean" },
        "minimum_valid_attestations": { "type": "integer", "minimum": 0, "maximum": 20 },
        "minimum_independence_groups": { "type": "integer", "minimum": 0, "maximum": 20 },
        "require_distinct_key_ids": { "type": "boolean" },
        "trust_policy_ref": { "$ref": "#/$defs/artifact_ref_or_none" }
      }
    },
    "trust_policy_admission": {
      "type": "object",
      "required": ["required", "satisfied", "assurance_scope", "evaluated_at", "valid_until", "trust_policy_ref", "effective_requirements", "receipt_quorum", "comparative_quorum", "blocking_codes"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "satisfied": { "type": "boolean" },
        "assurance_scope": {
          "type": "string",
          "enum": ["policy_eligibility_only", "authenticated_workload_and_policy_eligibility"]
        },
        "evaluated_at": { "$ref": "common.schema.json#/$defs/timestamp" },
        "valid_until": {
          "oneOf": [
            { "type": "string", "const": "none" },
            { "$ref": "common.schema.json#/$defs/timestamp" }
          ]
        },
        "trust_policy_ref": { "$ref": "#/$defs/artifact_ref_or_none" },
        "effective_requirements": {
          "type": "object",
          "required": ["minimum_valid_attestations", "minimum_independence_groups", "require_distinct_key_ids"],
          "additionalProperties": false,
          "properties": {
            "minimum_valid_attestations": { "type": "integer", "minimum": 0, "maximum": 20 },
            "minimum_independence_groups": { "type": "integer", "minimum": 0, "maximum": 20 },
            "require_distinct_key_ids": { "type": "boolean" }
          }
        },
        "receipt_quorum": { "$ref": "#/$defs/admission_quorum" },
        "comparative_quorum": { "$ref": "#/$defs/admission_quorum" },
        "identity_assurance": {
          "type": "object",
          "required": ["required", "satisfied", "authenticated_verifier_count", "distinct_trust_domain_count", "transparency_log_count", "evidence", "blocking_codes"],
          "additionalProperties": false,
          "properties": {
            "required": { "type": "boolean" },
            "satisfied": { "type": "boolean" },
            "authenticated_verifier_count": { "type": "integer", "minimum": 0, "maximum": 50 },
            "distinct_trust_domain_count": { "type": "integer", "minimum": 0, "maximum": 50 },
            "transparency_log_count": { "type": "integer", "minimum": 0, "maximum": 50 },
            "evidence": {
              "type": "array",
              "maxItems": 50,
              "items": {
                "type": "object",
                "required": ["verifier_id", "spiffe_id", "trust_domain", "certificate_sha256", "transparency_log_id", "purposes", "evidence_ref", "issued_at", "valid_until"],
                "additionalProperties": false,
                "properties": {
                  "verifier_id": { "$ref": "common.schema.json#/$defs/id" },
                  "spiffe_id": { "type": "string", "pattern": "^spiffe://[a-z0-9.-]+/[^?#]+$" },
                  "trust_domain": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$" },
                  "certificate_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "transparency_log_id": { "$ref": "common.schema.json#/$defs/id" },
                  "purposes": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": { "type": "string", "enum": ["verification_receipt", "comparative_evaluation_report"] }
                  },
                  "evidence_ref": { "$ref": "#/$defs/artifact_ref" },
                  "issued_at": { "$ref": "common.schema.json#/$defs/timestamp" },
                  "valid_until": { "$ref": "common.schema.json#/$defs/timestamp" }
                }
              }
            },
            "blocking_codes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
          }
        },
        "blocking_codes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "budget_snapshot": {
      "type": "object",
      "required": ["max_cycles", "cycles_observed", "max_retries_per_cycle", "retries_used_current_cycle", "max_failed_experiments", "failed_experiments", "max_no_progress_cycles", "consecutive_no_progress_cycles", "max_elapsed_minutes", "elapsed_minutes"],
      "additionalProperties": false,
      "properties": {
        "max_cycles": { "type": "integer", "minimum": 1 },
        "cycles_observed": { "type": "integer", "minimum": 0 },
        "max_retries_per_cycle": { "type": "integer", "minimum": 0 },
        "retries_used_current_cycle": { "type": "integer", "minimum": 0 },
        "max_failed_experiments": { "type": "integer", "minimum": 0 },
        "failed_experiments": { "type": "integer", "minimum": 0 },
        "max_no_progress_cycles": { "type": "integer", "minimum": 1 },
        "consecutive_no_progress_cycles": { "type": "integer", "minimum": 0 },
        "max_elapsed_minutes": { "type": "integer", "minimum": 1 },
        "elapsed_minutes": { "type": "integer", "minimum": 0 }
      }
    },
    "execution_authorized": { "type": "boolean" },
    "release_authorized": { "type": "boolean", "const": false },
    "human_decision_required": { "type": "boolean" },
    "required_human_decision": { "type": "string", "minLength": 1 },
    "blocking_codes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "generated_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  },
  "$defs": {
    "admission_quorum": {
      "type": "object",
      "required": ["required", "satisfied", "eligible_verifier_count", "distinct_key_count", "independence_group_count", "verifier_ids", "key_ids", "independence_groups"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "satisfied": { "type": "boolean" },
        "eligible_verifier_count": { "type": "integer", "minimum": 0, "maximum": 50 },
        "distinct_key_count": { "type": "integer", "minimum": 0, "maximum": 50 },
        "independence_group_count": { "type": "integer", "minimum": 0, "maximum": 50 },
        "verifier_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/id" } },
        "key_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
        "independence_groups": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" } }
      }
    },
    "artifact_ref": {
      "type": "object",
      "required": ["artifact_id", "relative_path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "$ref": "common.schema.json#/$defs/id" },
        "relative_path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "artifact_ref_or_none": {
      "type": "object",
      "required": ["artifact_id", "relative_path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "relative_path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^(none|[a-f0-9]{64})$" }
      }
    },
    "decision_ref_or_none": {
      "type": "object",
      "required": ["decision_id", "relative_path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "relative_path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^(none|[a-f0-9]{64})$" }
      }
    }
  }
}
