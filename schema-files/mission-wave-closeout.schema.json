{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/mission-wave-closeout.schema.json",
  "title": "Operational Mission Wave Closeout",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "mission_id",
    "wave_id",
    "status",
    "plan_ref",
    "report_ref",
    "aar_ref",
    "readiness_update_ref",
    "campaign_ref",
    "improvement_actions",
    "next_wave",
    "authority",
    "artifact_store",
    "closed_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "MissionWaveCloseout" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "wave_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["complete", "blocked_pending_execution", "blocked_pending_human_decision"] },
    "plan_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "report_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "aar_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "readiness_update_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "campaign_ref": {
      "type": "object",
      "required": ["artifact_id", "relative_path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "type": "string", "pattern": "^(none|[A-Z]+-[A-Za-z0-9_-]+)$" },
        "relative_path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^(none|[a-f0-9]{64})$" }
      }
    },
    "improvement_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["owner", "action_type", "description", "disposition"],
        "additionalProperties": false,
        "properties": {
          "owner": { "$ref": "common.schema.json#/$defs/role_id" },
          "action_type": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "disposition": { "type": "string", "enum": ["queued_in_bounded_campaign", "requires_human_decision", "record_only"] }
        }
      }
    },
    "next_wave": {
      "type": "object",
      "required": ["required", "reason", "trigger"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 },
        "trigger": { "type": "string", "enum": ["none", "improvement_candidate", "blocked_work", "human_decision"] }
      }
    },
    "authority": {
      "type": "object",
      "required": ["human_final_decision_authority", "release_authorized", "self_approval_prohibited"],
      "additionalProperties": false,
      "properties": {
        "human_final_decision_authority": { "type": "string", "const": "USER" },
        "release_authorized": { "type": "boolean", "const": false },
        "self_approval_prohibited": { "type": "boolean", "const": true }
      }
    },
    "artifact_store": {
      "type": "object",
      "required": ["verified", "manifest_revision", "manifest_sha256"],
      "additionalProperties": false,
      "properties": {
        "verified": { "type": "boolean", "const": true },
        "manifest_revision": { "type": "integer", "minimum": 1 },
        "manifest_sha256": { "$ref": "common.schema.json#/$defs/sha256" }
      }
    },
    "closed_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
