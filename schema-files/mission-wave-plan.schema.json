{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/mission-wave-plan.schema.json",
  "title": "Operational Mission Wave Plan",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "mission_id",
    "wave_id",
    "title",
    "objective",
    "success_conditions",
    "failure_conditions",
    "constraints",
    "mission_profile",
    "agents",
    "model_assignment",
    "authority",
    "adaptive_work",
    "created_at",
    "valid_until"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "MissionWavePlan" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "wave_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "success_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mission_profile": {
      "type": "object",
      "required": ["classification", "risk_level", "roe_class", "release_target"],
      "additionalProperties": false,
      "properties": {
        "classification": { "$ref": "common.schema.json#/$defs/classification" },
        "risk_level": { "$ref": "common.schema.json#/$defs/risk_level" },
        "roe_class": { "$ref": "common.schema.json#/$defs/roe_class" },
        "release_target": {
          "type": "string",
          "enum": ["internal_working", "internal_handoff", "final_output", "external_release"]
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "agent_id",
          "operational_role",
          "department",
          "task",
          "model_billet_id",
          "delegated_authority",
          "allowed_actions",
          "approval_required",
          "prohibited_actions",
          "context_scope"
        ],
        "additionalProperties": false,
        "properties": {
          "agent_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
          "operational_role": { "$ref": "common.schema.json#/$defs/role_id" },
          "department": {
            "type": "string",
            "enum": ["command", "coordination", "research", "intelligence", "operations", "effects", "sustainment", "protection", "systems", "red_team", "recorder", "maintenance"]
          },
          "task": { "type": "string", "minLength": 1 },
          "model_billet_id": { "type": "string", "minLength": 1 },
          "delegated_authority": {
            "type": "string",
            "enum": ["scoped-execution", "source-verification", "release-review", "risk-review", "maintenance", "coordination", "document-routing"]
          },
          "allowed_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "approval_required": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "prohibited_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "context_scope": { "$ref": "common.schema.json#/$defs/classification" }
        }
      }
    },
    "model_assignment": {
      "type": "object",
      "required": ["required", "integrated_preflight_ref"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "integrated_preflight_ref": {
          "type": "object",
          "required": ["artifact_id", "relative_path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "artifact_id": { "type": "string", "pattern": "^(none|[A-Z]+-[A-Za-z0-9_-]+)$" },
            "relative_path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^(none|[a-f0-9]{64})$" }
          }
        }
      }
    },
    "dispatch_control": {
      "type": "object",
      "required": [
        "required",
        "enforcement_level",
        "gateway_exclusive",
        "policy_authorizations"
      ],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean", "const": true },
        "enforcement_level": { "type": "string", "const": "guardrail" },
        "gateway_exclusive": { "type": "boolean", "const": false },
        "policy_authorizations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "type": "object",
            "required": [
              "agent_id",
              "provider",
              "policy_id",
              "draft_sha256"
            ],
            "additionalProperties": false,
            "properties": {
              "agent_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
              },
              "provider": {
                "type": "string",
                "enum": ["codex", "claude_code"]
              },
              "policy_id": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "draft_sha256": {
                "$ref": "common.schema.json#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "human_final_decision_authority",
        "routing_required_every_wave",
        "repository_artifacts_required",
        "approval_required_for_scope_change",
        "approval_required_for_commit",
        "approval_required_for_push",
        "approval_required_for_merge",
        "approval_required_for_release",
        "self_approval_prohibited"
      ],
      "additionalProperties": false,
      "properties": {
        "human_final_decision_authority": { "type": "string", "const": "USER" },
        "routing_required_every_wave": { "type": "boolean", "const": true },
        "repository_artifacts_required": { "type": "boolean", "const": true },
        "approval_required_for_scope_change": { "type": "boolean", "const": true },
        "approval_required_for_commit": { "type": "boolean", "const": true },
        "approval_required_for_push": { "type": "boolean", "const": true },
        "approval_required_for_merge": { "type": "boolean", "const": true },
        "approval_required_for_release": { "type": "boolean", "const": true },
        "self_approval_prohibited": { "type": "boolean", "const": true }
      }
    },
    "adaptive_work": {
      "type": "object",
      "required": ["enabled", "campaign_id", "target_type", "acceptance_criteria", "non_goals", "max_cycles", "max_changed_files", "max_elapsed_minutes"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "campaign_id": { "$ref": "common.schema.json#/$defs/id" },
        "target_type": {
          "type": "string",
          "enum": ["work_product", "test_fixture", "documentation", "procedure", "runtime_control", "skill", "policy"]
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "non_goals": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "max_cycles": { "type": "integer", "minimum": 1, "maximum": 32 },
        "max_changed_files": { "type": "integer", "minimum": 1, "maximum": 200 },
        "max_elapsed_minutes": { "type": "integer", "minimum": 1, "maximum": 10080 }
      }
    },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "valid_until": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
