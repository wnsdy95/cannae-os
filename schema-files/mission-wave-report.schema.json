{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/mission-wave-report.schema.json",
  "title": "Operational Mission Wave Report",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "mission_id",
    "wave_id",
    "plan_ref",
    "routing_preflight_ref",
    "agent_results",
    "wave_status",
    "human_decisions_required",
    "release_requested",
    "recorded_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "MissionWaveReport" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "wave_id": { "type": "string", "minLength": 1 },
    "plan_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "routing_preflight_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "agent_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["agent_id", "context_pack_ref", "status", "summary", "completed_actions", "blockers", "evidence_refs", "improvement_candidates", "next_actions"],
        "additionalProperties": false,
        "properties": {
          "agent_id": { "type": "string", "minLength": 1 },
          "context_pack_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
          "status": { "type": "string", "enum": ["complete", "blocked", "failed"] },
          "summary": { "type": "string", "minLength": 1 },
          "completed_actions": { "$ref": "common.schema.json#/$defs/string_list" },
          "blockers": { "$ref": "common.schema.json#/$defs/string_list" },
          "evidence_refs": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/artifact_ref" }
          },
          "improvement_candidates": { "$ref": "common.schema.json#/$defs/string_list" },
          "next_actions": { "$ref": "common.schema.json#/$defs/string_list" }
        }
      }
    },
    "wave_status": { "type": "string", "enum": ["complete", "blocked", "failed"] },
    "human_decisions_required": { "$ref": "common.schema.json#/$defs/string_list" },
    "release_requested": { "type": "boolean", "const": false },
    "recorded_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
