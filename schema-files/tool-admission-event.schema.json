{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/tool-admission-event.schema.json",
  "title": "Tool Admission Event",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "mission_id",
    "wave_id",
    "agent_id",
    "provider",
    "session_binding",
    "lease_ref",
    "tool_policy_ref",
    "checkpoint_ref",
    "tool_use_id",
    "tool_name",
    "operation_class",
    "rule_id",
    "tool_input_sha256",
    "request_sha256",
    "sequence",
    "state_before",
    "decision",
    "reason_codes",
    "authority",
    "decided_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "ToolAdmissionEvent" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "wave_id": { "$ref": "#/$defs/safe_identifier" },
    "agent_id": { "$ref": "#/$defs/safe_identifier" },
    "provider": { "$ref": "#/$defs/provider" },
    "session_binding": { "$ref": "#/$defs/session_binding" },
    "lease_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "tool_policy_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "checkpoint_ref": { "$ref": "common.schema.json#/$defs/artifact_ref" },
    "tool_use_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "tool_name": { "$ref": "#/$defs/tool_name" },
    "operation_class": { "$ref": "#/$defs/operation_class" },
    "rule_id": { "$ref": "#/$defs/rule_id" },
    "tool_input_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "request_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "state_before": { "$ref": "#/$defs/repository_state" },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "reason_codes": { "$ref": "#/$defs/reason_codes" },
    "authority": { "$ref": "#/$defs/authority" },
    "decided_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  },
  "$defs": {
    "safe_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "provider": {
      "type": "string",
      "enum": ["codex", "claude_code"]
    },
    "session_binding": {
      "type": "object",
      "required": ["session_id", "provider_agent_id"],
      "additionalProperties": false,
      "properties": {
        "session_id": { "$ref": "#/$defs/safe_identifier" },
        "provider_agent_id": { "$ref": "#/$defs/safe_identifier" }
      }
    },
    "tool_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+/-]*$"
    },
    "rule_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "operation_class": {
      "type": "string",
      "enum": [
        "observe",
        "repository_read",
        "repository_write",
        "process_execute",
        "network_access",
        "delegation"
      ]
    },
    "repository_state": {
      "type": "object",
      "required": ["head_commit", "worktree_fingerprint", "dirty"],
      "additionalProperties": false,
      "properties": {
        "head_commit": {
          "type": "string",
          "pattern": "^(unborn|[a-f0-9]{40,64})$"
        },
        "worktree_fingerprint": { "$ref": "common.schema.json#/$defs/sha256" },
        "dirty": { "type": "boolean" }
      }
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "human_final_decision_authority",
        "self_approval_prohibited",
        "release_authorized"
      ],
      "additionalProperties": false,
      "properties": {
        "human_final_decision_authority": { "type": "string", "const": "USER" },
        "self_approval_prohibited": { "type": "boolean", "const": true },
        "release_authorized": { "type": "boolean", "const": false }
      }
    }
  }
}
