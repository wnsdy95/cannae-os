{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/frago.schema.json",
  "title": "FRAGO Event",
  "type": "object",
  "required": ["id", "mission_id", "parent_order", "reason", "unchanged_intent", "modified_tasks"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "parent_order": { "$ref": "common.schema.json#/$defs/id" },
    "reason": { "type": "string", "minLength": 1 },
    "unchanged_intent": { "$ref": "common.schema.json#/$defs/string_list" },
    "modified_tasks": { "$ref": "common.schema.json#/$defs/string_list" },
    "new_constraints": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
