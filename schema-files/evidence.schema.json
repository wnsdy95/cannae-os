{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/evidence.schema.json",
  "title": "Evidence Record",
  "type": "object",
  "required": ["id", "mission_id", "source_title", "url", "source_type", "reliability", "claim", "interpretation", "linked_docs"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "mission_id": { "$ref": "common.schema.json#/$defs/id" },
    "source_title": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "format": "uri" },
    "source_type": { "type": "string", "minLength": 1 },
    "reliability": { "type": "string", "enum": ["A", "B", "C", "D"] },
    "claim": { "type": "string", "minLength": 1 },
    "interpretation": { "type": "string", "minLength": 1 },
    "linked_docs": { "$ref": "common.schema.json#/$defs/string_list" },
    "checked_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
