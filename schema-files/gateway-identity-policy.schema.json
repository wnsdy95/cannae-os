{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controls.local/schema-files/gateway-identity-policy.schema.json",
  "title": "Gateway Identity Policy",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "gateway",
    "repository_binding",
    "adapter_profile",
    "transport_profile",
    "trusted_x509_roots",
    "principals",
    "revocations",
    "challenge_ttl_seconds",
    "evidence_ttl_seconds",
    "valid_from",
    "expires_at",
    "authority"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "type": { "type": "string", "const": "GatewayIdentityPolicy" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "gateway": { "$ref": "#/$defs/gateway" },
    "repository_binding": { "$ref": "#/$defs/repository_binding" },
    "adapter_profile": { "$ref": "#/$defs/adapter_profile" },
    "transport_profile": { "$ref": "#/$defs/transport_profile" },
    "trusted_x509_roots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/trusted_x509_root" }
    },
    "principals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/principal" }
    },
    "revocations": { "$ref": "#/$defs/revocations" },
    "challenge_ttl_seconds": {
      "type": "integer",
      "minimum": 5,
      "maximum": 300
    },
    "evidence_ttl_seconds": {
      "type": "integer",
      "minimum": 5,
      "maximum": 900
    },
    "valid_from": { "$ref": "common.schema.json#/$defs/timestamp" },
    "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "authority": { "$ref": "#/$defs/authority" }
  },
  "$defs": {
    "safe_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "provider": {
      "type": "string",
      "enum": ["codex", "claude_code"]
    },
    "repository_binding": {
      "type": "object",
      "required": ["repository_key", "identity_fingerprint"],
      "additionalProperties": false,
      "properties": {
        "repository_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "identity_fingerprint": { "$ref": "common.schema.json#/$defs/sha256" }
      }
    },
    "gateway": {
      "type": "object",
      "required": [
        "gateway_id",
        "instance_id",
        "audience",
        "deployment_sha256",
        "configuration_sha256",
        "assurance_level",
        "exclusive_path_verified"
      ],
      "additionalProperties": false,
      "properties": {
        "gateway_id": { "$ref": "#/$defs/safe_identifier" },
        "instance_id": { "$ref": "#/$defs/safe_identifier" },
        "audience": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "deployment_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "configuration_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "assurance_level": {
          "type": "string",
          "const": "authenticated_reference"
        },
        "exclusive_path_verified": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "adapter_profile": {
      "type": "object",
      "required": [
        "adapter_id",
        "adapter_version",
        "adapter_sha256",
        "runtime_sha256",
        "configuration_sha256",
        "signing_key_id",
        "signing_algorithm",
        "signing_public_key_pem"
      ],
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "$ref": "#/$defs/safe_identifier" },
        "adapter_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "adapter_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "runtime_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "configuration_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "signing_key_id": { "$ref": "common.schema.json#/$defs/sha256" },
        "signing_algorithm": {
          "type": "string",
          "const": "ed25519"
        },
        "signing_public_key_pem": {
          "type": "string",
          "minLength": 64,
          "maxLength": 8192
        }
      }
    },
    "transport_profile": {
      "type": "object",
      "required": [
        "transport",
        "minimum_tls_version",
        "maximum_tls_version",
        "require_client_certificate",
        "allow_early_data",
        "tls_exporter_label",
        "tls_exporter_length",
        "server_certificate_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "transport": {
          "type": "string",
          "const": "mtls_spiffe_x509"
        },
        "minimum_tls_version": {
          "type": "string",
          "const": "TLSv1.3"
        },
        "maximum_tls_version": {
          "type": "string",
          "const": "TLSv1.3"
        },
        "require_client_certificate": {
          "type": "boolean",
          "const": true
        },
        "allow_early_data": {
          "type": "boolean",
          "const": false
        },
        "tls_exporter_label": {
          "type": "string",
          "const": "EXPORTER-Channel-Binding"
        },
        "tls_exporter_length": {
          "type": "integer",
          "const": 32
        },
        "server_certificate_sha256": {
          "$ref": "common.schema.json#/$defs/sha256"
        }
      }
    },
    "trusted_x509_root": {
      "type": "object",
      "required": [
        "id",
        "trust_domain",
        "certificate_pem",
        "certificate_sha256",
        "valid_until"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/safe_identifier" },
        "trust_domain": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253,
          "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
        },
        "certificate_pem": {
          "type": "string",
          "minLength": 64,
          "maxLength": 32768
        },
        "certificate_sha256": {
          "$ref": "common.schema.json#/$defs/sha256"
        },
        "valid_until": { "$ref": "common.schema.json#/$defs/timestamp" }
      }
    },
    "principal": {
      "type": "object",
      "required": [
        "id",
        "agent_id",
        "provider",
        "spiffe_id",
        "trust_root_id"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/safe_identifier" },
        "agent_id": { "$ref": "#/$defs/safe_identifier" },
        "provider": { "$ref": "#/$defs/provider" },
        "spiffe_id": {
          "type": "string",
          "pattern": "^spiffe://[a-z0-9.-]+/[^?#]+$"
        },
        "trust_root_id": { "$ref": "#/$defs/safe_identifier" }
      }
    },
    "revocations": {
      "type": "object",
      "required": ["principal_ids", "certificate_sha256"],
      "additionalProperties": false,
      "properties": {
        "principal_ids": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/safe_identifier" }
        },
        "certificate_sha256": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": { "$ref": "common.schema.json#/$defs/sha256" }
        }
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "human_final_decision_authority",
        "self_approval_prohibited",
        "production_execution_authorized",
        "release_authorized"
      ],
      "additionalProperties": false,
      "properties": {
        "human_final_decision_authority": {
          "type": "string",
          "const": "USER"
        },
        "self_approval_prohibited": {
          "type": "boolean",
          "const": true
        },
        "production_execution_authorized": {
          "type": "boolean",
          "const": false
        },
        "release_authorized": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
